public class Cinco {

    public static void main(String[] args) {
      
        double[] notas = {3,7,2,9,5,1,8,4};
        double soma= 0;
        
        for (int i = 0; i < notas.length; i++) {
            soma += notas[i];
        }
        double media = soma / notas.length;
        
        System.out.println("Média:" + media);
    }
}
